# World ID Developer Portal — https://developer.worldcoin.org
# Create an app, add action "register-field-agent", copy the App ID here.
VITE_WORLD_ID_APP_ID=app_staging_your_app_id_here

# EmailJS — https://emailjs.com (free tier: 200 emails/month)
# Create a service, add two templates (application received + account approved).
# Template variables used: to_email, to_name, role_label, subject, message, login_url
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxx
VITE_EMAILJS_TEMPLATE_APPLIED=template_xxxxxxx
VITE_EMAILJS_TEMPLATE_APPROVED=template_xxxxxxx
